                                                                "box": {
                                                                    "code": "out1 = in1;\r\nout2 = in2;\r\n\r\nxdist = in1 - centerx;\r\nydist = in2 - centery;\r\n\r\n\r\ndist = sqrt(pow(xdist, 2) + pow(ydist, 2));\r\n\r\nxrot = xdist * cos(-angle) + ydist * sin(-angle);\r\nyrot = - xdist * sin(-angle) + ydist * cos(-angle);\r\n\r\nout3 = amp * exp(-0.5 * (pow(xrot / longradius, 2) + pow(yrot / smallradius, 2)));",
