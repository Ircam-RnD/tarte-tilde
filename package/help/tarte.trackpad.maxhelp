                                    "patching_rect": [ 394.0, 697.0, 177.0, 22.0 ],
                                    "text": "jit.gl.shader @name colorshade",
                                    "textfile": {
                                        "text": "<jittershader name=\"fcolor-shade\">\n\t<description>Trackpad color shader</description>\n\t<param name=\"position\" type=\"vec3\" state=\"POSITION\" />\n\t<param name=\"normal\" type=\"vec3\" state=\"NORMAL\" />\n\t<param name=\"modelViewProjectionMatrix\" type=\"mat4\" state=\"MODELVIEW_PROJECTION_MATRIX\" />\n\t<param name=\"color\" type=\"vec4\" state=\"COLOR\" />\n\t<language name=\"glsl\" version=\"1.5\">\n\t\t<bind param=\"position\" program=\"vp\" />\n\t\t<bind param=\"normal\" program=\"vp\" />\n\t\t<bind param=\"modelViewProjectionMatrix\" program=\"vp\" />\n\t\t<bind param=\"normalMatrix\" program=\"vp\" />\n\t\t<bind param=\"color\" program=\"vp\" />\n\t\t<program name=\"vp\" type=\"vertex\">\n<![CDATA[\n#version 330 core\nuniform mat4 modelViewProjectionMatrix;\nuniform mat3 normalMatrix;\nin vec3 position;\nin vec3 normal;\nin vec4 color;\nout jit_PerVertex {\n\tvec4 color;\n\tfloat vZ;\n\tvec3 vNormal;\n} jit_out;\nvoid main() {\n\tgl_Position = modelViewProjectionMatrix * vec4(position, 1.);\n\tjit_out.color = color;\n\tjit_out.vZ = position.y;  // object-space Z\n\tjit_out.vNormal = normalize(normal);\n}\n]]>\n\t\t</program>\n\t\t<program name=\"fp\" type=\"fragment\">\n<![CDATA[\n#version 330 core\nin jit_PerVertex {\n\tvec4 color;\n\tfloat vZ;\n\tvec3 vNormal;\n} jit_in;\nout vec4 outcolor;\nvoid main() {\n\t// Z-based color gradient\n\tfloat zMin = -0.0;\n\tfloat zMax =  1.0;\n\tfloat t = clamp((jit_in.vZ - zMin) / (zMax - zMin), 0.0, 1.0);\n\tvec3 colorLight1 = mix(vec3(0.2, 0.2, 0.2), vec3(0.0, 0.3, 0.8), t);\n\tvec3 colorLight2 = mix(vec3(0.2, 0.2, 0.2), vec3(1.0, 0.2, 0.7), t);\n\n\t// Directional light from the right\n\tvec3 lightDir = normalize(vec3(0.0, 1.0, 1.0));\n\tvec3 lightDir2 = normalize(vec3(1.0, 1.0, 0.0));\n\tfloat ambient = 0.1;\n\tfloat diffuse = max(dot(jit_in.vNormal, lightDir), 0.);\n\tfloat diffuse2 = max(dot(jit_in.vNormal, lightDir2), 0.);\n\n\t// Combine lighting with color\n\tvec3 lit = colorLight1 * (ambient + diffuse) + colorLight2 * (diffuse2);\n\n\t// Z-based alpha\n\tfloat alpha = mix(0.2, 1.0, t);\n\toutcolor = vec4(lit, alpha);\n}\n]]>\n\t\t</program>\n\t</language>\n</jittershader>",
                                        "filename": "none",
                                        "flags": 0,
                                        "embed": 1,
                                        "autowatch": 1
                                    }
                                }
